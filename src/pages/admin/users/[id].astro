---
// SSR: id — произвольный UUID пользователя, неизвестен на этапе сборки
// (не список фиксированных значений, как у симптомов через getStaticPaths).
export const prerender = false;

import AppLayout from "../../../layouts/AppLayout.astro";
import UserDetail from "../../../components/admin/UserDetail";

const { id } = Astro.params;
---
<AppLayout title="Пользователь — Vitaminia">
  <UserDetail client:load userId={id} />
</AppLayout>
