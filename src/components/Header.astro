---
---
<header class="site-header">
  <div class="site-header__inner">

    <a href="/" class="logo" aria-label="Vitaminia.mx — ir al inicio">
      <img class="logo__icon" src="/logo.svg" width="44" height="44" alt="" aria-hidden="true" />

      <div class="logo__text">
        <span class="logo__name">Vitaminia</span>
        <span class="logo__tagline">Tu país de vitaminas</span>
      </div>
    </a>

    <nav class="site-nav" aria-label="Navegación principal">
      <ul class="site-nav__list">
        <li><a href="/vitaminas" class="site-nav__link">Vitaminas</a></li>
        <li><a href="/minerales" class="site-nav__link">Minerales</a></li>
        <li><a href="/nutrientes" class="site-nav__link">Nutrientes</a></li>
        <li><a href="/suplementos" class="site-nav__link">Suplementos</a></li>
        <li><a href="/how-it-works" class="site-nav__link">Cómo funciona</a></li>
      </ul>
    </nav>

  </div>
</header>

<style>
  .site-header {
    background: #ffffff;
    border-bottom: 1px solid var(--color-border, #e8eaed);
    position: sticky;
    top: 0;
    z-index: 100;
    box-shadow: var(--shadow-sm, 0 1px 3px rgba(93,181,61,.06));
  }
  .site-header__inner {
    max-width: var(--container-wide, 1100px);
    margin: 0 auto;
    padding: 0 var(--space-4, 1rem);
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-8, 2rem);
  }
  .logo {
    display: flex;
    align-items: center;
    gap: var(--space-3, 0.75rem);
    text-decoration: none;
    flex-shrink: 0;
  }
  .logo__icon { flex-shrink: 0; }
  .logo__text {
    display: flex;
    flex-direction: column;
    gap: 1px;
  }
  .logo__name {
    font-size: 1.25rem;
    font-weight: 700;
    line-height: 1;
    letter-spacing: -0.01em;
    color: var(--color-neutral-900, #1a1a2e);
  }
  .logo__tagline {
    font-size: 0.6rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    color: var(--color-text-secondary, #5a6272);
    text-transform: uppercase;
  }
  .site-nav__list {
    display: flex;
    align-items: center;
    gap: var(--space-1, 0.25rem);
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .site-nav__link {
    display: block;
    padding: var(--space-2, 0.5rem) var(--space-4, 1rem);
    font-size: var(--font-size-sm, 0.875rem);
    font-weight: var(--font-weight-medium, 500);
    color: var(--color-text-secondary, #5a6272);
    text-decoration: none;
    border-radius: var(--radius-md, 8px);
    transition: color 0.15s, background 0.15s;
  }
  .site-nav__link:hover {
    color: var(--color-accent-default, #5DB53D);
    background: var(--color-neutral-50, #f8f9fb);
    text-decoration: none;
  }
  @media (max-width: 760px) {
    .site-nav__list { gap: 0; }
    .site-nav__link { padding: var(--space-2, 0.5rem) var(--space-2, 0.5rem); font-size: 0.8rem; }
  }
  @media (max-width: 600px) {
    .site-header__inner { gap: var(--space-3, 0.75rem); }
    .site-nav__list {
      flex-wrap: nowrap;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      max-width: 100%;
    }
    .site-nav__list::-webkit-scrollbar { display: none; }
    .site-nav__link { white-space: nowrap; }
  }
  @media (max-width: 480px) {
    .logo__tagline { display: none; }
    .site-nav__link { padding: var(--space-2, 0.5rem) var(--space-3, 0.75rem); }
  }
</style>
