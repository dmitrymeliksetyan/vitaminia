# Скопируйте этот файл в .env (локальная разработка) и заполните реальными
# значениями. На сервере — см. DEPLOY.md, раздел "Секреты": файл называется
# .env.production и лежит рядом с checkout'ом проекта, читается
# scripts/deploy/run-server.mjs при старте Node-процесса под PM2.
#
# Infrastructure v2: раньше секреты и публичные переменные были разнесены по
# двум разным механизмам (.env + .dev.vars, из-за особенностей Cloudflare
# Pages Functions runtime). Теперь всё в одном месте — обычные переменные
# окружения Node-процесса (см. astro.config.mjs: `import "dotenv/config"` в
# самом верху, и src/lib/assistant/runtime-env.ts — единственная точка
# чтения секретов серверным кодом).

# --- Публичные переменные (инлайнятся в клиентский бандл Vite/Astro,
#     ВИДНЫ в браузере — не должны быть секретами) ---
# Supabase Dashboard → Settings → API → Project URL и anon/public key.
# anon key безопасен для публикации по дизайну (защищён RLS).
PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# --- Серверные секреты (НИКОГДА не должны иметь префикс PUBLIC_, никогда
#     не коммитятся, никогда не попадают в клиентский бандл) ---

# Помощник сайта (src/pages/api/assistant/*) — отдельная от AI-редакции
# фича, обычный пользовательский чат-помощник по сайту. НЕ связана с
# производством контента: после этапа "Выделение AI Worker в отдельный
# независимый сервис" вся AI-редакция (research/draft/medical_review/
# final_review/seo_review/AI-стратег) переехала в medizin-worker вместе со
# своим собственным ANTHROPIC_API_KEY — эта переменная здесь нужна ТОЛЬКО
# Помощнику, не производству статей.
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-5

# Service-role доступ к таблицам с RLS без policy для anon/authenticated
# (feedback_messages, analytics_events и т.п.) — Supabase Dashboard →
# Settings → API → service_role key.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Форма обратной связи (src/pages/api/feedback.ts)
RESEND_API_KEY=re_...
FEEDBACK_EMAIL=dmitrymeliksetyan@gmail.com
# Необязательно — до подтверждения домена medizin.ru в Resend оставьте
# пустым, сработает безопасный дефолт onboarding@resend.dev (см. resend.ts).
RESEND_FROM_EMAIL=

# Продуктовая аналитика + доступ к /admin — whitelist по user_id (список
# UUID через запятую). Узнать свой UUID: Supabase Dashboard →
# Authentication → Users → скопировать UID своего аккаунта.
ADMIN_USER_IDS=00000000-0000-0000-0000-000000000000

# Этап "Выделение AI Worker в отдельный независимый сервис" — GITHUB_TOKEN/
# GITHUB_REPO/GITHUB_BRANCH УБРАНЫ отсюда. Публикация материалов (git commit
# + push) и вся AI-редакция теперь целиком выполняются отдельным проектом
# medizin-worker, у которого свой собственный .env (см.
# medizin-worker/.env.example) — сайт (medizin) больше НЕ обращается к
# GitHub API ни для чтения, ни для записи, и не хранит GitHub-токен вообще.

# --- Только для Node-сервера в production (необязательно для локальной
#     разработки — см. scripts/deploy/run-server.mjs и ecosystem.config.cjs) ---
# Порт и хост, на которых слушает standalone Node-сервер Astro (@astrojs/node).
# nginx проксирует /assistant, /my, /admin, /api именно сюда — см.
# nginx/medizin.conf.
HOST=127.0.0.1
PORT=4321
